                </svg> 
            </span>
            <span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 32 32" width="24" height="24">
                    <title>LinkedIn</title>
                    <path fill="currentColor" d="M8.25 28H2.437V9.313H8.25V28ZM5.375 6.75c-.917 0-1.708-.333-2.375-1S2 4.292 2 3.375 2.333 1.667 3 1s1.458-1 2.375-1S7.083.333 7.75 1s1 1.458 1 2.375-.333 1.708-1 2.375-1.458 1-2.375 1ZM30 28h-5.813v-9.125c0-1.5-.125-2.583-.375-3.25-.458-1.125-1.354-1.687-2.687-1.687-1.333 0-2.27.5-2.813 1.5-.416.75-.625 1.854-.625 3.312V28h-5.75V9.313H17.5v2.562h.063c.416-.833 1.083-1.52 2-2.062 1-.667 2.166-1 3.5-1 2.708 0 4.604.854 5.687 2.562.833 1.375 1.25 3.5 1.25 6.375V28Z"/>
                </svg> 
            </span>
        </section>

        <form class="footer-newsletter" action="">
            <label for="">Blijf op de hoogte
                <input type="email" placeholder="voorbeeld@email.nl">
            </label>
            <button type="submit"></button>
        </form>

        <section class="footer-bottom">
            <nav class="footer-legal">
                <ul>
                    <li><a href="/niet-beschikbaar">Cookies</a></li>
                    <li><a href="/niet-beschikbaar">Privacy</a></li>
                    <li><a href="/niet-beschikbaar">Disclaimer</a></li>
                    <li><a href="/niet-beschikbaar">Algemene voorwaarden</a></li>
                    <li><a href="/niet-beschikbaar">Contact</a></li>
                </ul>
            </nav>
            <ul class="footer-partners">
                <li><a href="/niet-beschikbaar"><img src="/assets/images/mvocew.svg" alt="Museumvereniging"></a></li>
                <li><a href="/niet-beschikbaar"><img src="/assets/images/vriendenloterij.svg" alt="Vriendenloterij"></a></li>
                <li><a href="/niet-beschikbaar"><img src="/assets/images/haarlem.svg" alt="Gemeente Haarlem"></a></li>
            </ul>
        </section>
    </footer>
    <script src="/js/main.js"></script>
</body>
</html>   